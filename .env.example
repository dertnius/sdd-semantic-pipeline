# ── SDD Semantic Pipeline — environment variable template ─────────────────────
# Copy this file to .env and customise as needed.
# The pipeline reads all PIPELINE_* variables via pydantic-settings.

# ── Pandoc ────────────────────────────────────────────────────────────────────
# Input format passed to pandoc --from.
# Most Confluence exports work with gfm (GitHub Flavored Markdown).
PIPELINE_PANDOC_FROM_FORMAT=gfm

# ── Language (EN/DE/FR/IT enrichment) ─────────────────────────────────────────
# Rule pack for enrichment: en (default) | de | fr | it, or 'auto' to detect per
# document (auto needs the optional [lang] extra: pip install "sdd-pipeline[lang]").
PIPELINE_LANGUAGE=en
# Model-free search: skip dense embedding and rank by BM25 only — no embedding model
# is loaded, works for every language. Auto-enabled when the index was built lexical.
# PIPELINE_LEXICAL_ONLY=false
# Snowball stemming for BM25 recall (needs [stem]; only safe on a single-language index).
# PIPELINE_LEXICAL_STEMMING=false

# ── Embedding ─────────────────────────────────────────────────────────────────
# Only used for SEMANTIC (non-lexical) search. HuggingFace sentence-transformers model.
# English-only production model:
PIPELINE_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# MULTILINGUAL (EN/DE/FR/IT semantic search) — switch the model AND re-index:
#   local:  PIPELINE_EMBEDDING_MODEL=BAAI/bge-m3            (also: intfloat/multilingual-e5-large)
#   azure:  PIPELINE_EMBEDDING_PROVIDER=azure + a text-embedding-3-large deployment (no download)
# Development / CI (fast download, ~80 MB):
# PIPELINE_EMBEDDING_MODEL=all-MiniLM-L6-v2
#
# Offline / restricted network (HuggingFace blocked): side-load the model folder
# onto the box and point at a LOCAL PATH instead of a hub id — sentence-
# transformers loads either. Also export HF_HUB_OFFLINE=1 in your shell so it
# never attempts the hub. See README "Offline / air-gapped model" notes.
# PIPELINE_EMBEDDING_MODEL=./models/bge-large-en-v1.5

# ── Embedding provider ────────────────────────────────────────────────────────
# Backend selection: local (sentence-transformers, default) or azure (Azure OpenAI).
PIPELINE_EMBEDDING_PROVIDER=local
# Azure OpenAI settings (only used when PIPELINE_EMBEDDING_PROVIDER=azure):
# Requires the optional dependency:  pip install "sdd-pipeline[azure]"
# PIPELINE_AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# PIPELINE_AZURE_OPENAI_DEPLOYMENT=<your-embeddings-deployment>
# PIPELINE_AZURE_OPENAI_API_VERSION=2024-10-21
# SECRET — do NOT commit. Set in your shell/CI, not in a committed .env:
# PIPELINE_AZURE_OPENAI_API_KEY=

# ── Workspace contract (inbox / outbox) ───────────────────────────────────────
# All pipeline INPUT must live under the inbox; all OUTPUT under the outbox
# (subfolders allowed). Defaults point into these zones, so bare commands need
# no path flags. Out-of-zone paths are rejected unless enforcement is off.
PIPELINE_INBOX_DIR=./inbox
PIPELINE_OUTBOX_DIR=./outbox
PIPELINE_ENFORCE_WORKSPACE=true

# ── Chunking ──────────────────────────────────────────────────────────────────
# Maximum characters per semantic chunk before splitting.
PIPELINE_MAX_CHUNK_CHARS=2000

# ── Vector store ──────────────────────────────────────────────────────────────
# Backend selection: memory (langchain-core InMemoryVectorStore, default) or
# chroma (ChromaDB). chroma requires the optional dependency:
#   pip install "sdd-pipeline[chroma]"
PIPELINE_VECTOR_STORE_BACKEND=memory
# Directory where the vector index persists (Chroma files, or
# <collection>.json + <collection>.provenance.json for the memory backend).
# Must stay under the outbox (it is a pipeline output).
PIPELINE_CHROMA_PERSIST_DIR=./outbox/index
# Collection name inside the vector store.
PIPELINE_COLLECTION_NAME=sdd_docs

# ── Telemetry ─────────────────────────────────────────────────────────────────
# Opt out of ChromaDB anonymous telemetry (chroma backend only).
ANONYMIZED_TELEMETRY=false

# ── Downloader (optional SiteMinder ingestion: sdd-pipeline download) ──────────
# Only used by the `download` command (extra: pip install "sdd-pipeline[download]").
# Auth strategy: cookie (pre-issued SMSESSION, primary) | form | bearer | none.
# PIPELINE_DOWNLOAD_AUTH=cookie
# SECRETS — set in your shell/CI (masked), NEVER in a committed .env:
# PIPELINE_DOWNLOAD_COOKIE=          # pre-issued SMSESSION cookie value (auth=cookie)
# PIPELINE_DOWNLOAD_BEARER=          # bearer token (auth=bearer)
# Form login (auth=form) — needed only if no MFA on the service account:
# PIPELINE_DOWNLOAD_LOGIN_URL=https://sso.example.com/login
# PIPELINE_DOWNLOAD_USERNAME=
# PIPELINE_DOWNLOAD_PASSWORD=        # SECRET
# PIPELINE_DOWNLOAD_USER_FIELD=USER
# PIPELINE_DOWNLOAD_PASS_FIELD=PASSWORD
# PIPELINE_DOWNLOAD_COOKIE_NAME=SMSESSION
