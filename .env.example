# ── SDD Semantic Pipeline — environment variable template ─────────────────────
# Copy this file to .env and customise as needed.
# The pipeline reads all PIPELINE_* variables via pydantic-settings.

# ── Pandoc ────────────────────────────────────────────────────────────────────
# Input format passed to pandoc --from.
# Most Confluence exports work with gfm (GitHub Flavored Markdown).
PIPELINE_PANDOC_FROM_FORMAT=gfm

# ── Embedding ─────────────────────────────────────────────────────────────────
# HuggingFace sentence-transformers model name.
# Production (highest quality):
PIPELINE_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# Development / CI (fast download, ~80 MB):
# PIPELINE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Embedding provider ────────────────────────────────────────────────────────
# Backend selection: local (sentence-transformers, default) or azure (Azure OpenAI).
PIPELINE_EMBEDDING_PROVIDER=local
# Azure OpenAI settings (only used when PIPELINE_EMBEDDING_PROVIDER=azure):
# Requires the optional dependency:  pip install "sdd-pipeline[azure]"
# PIPELINE_AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# PIPELINE_AZURE_OPENAI_DEPLOYMENT=<your-embeddings-deployment>
# PIPELINE_AZURE_OPENAI_API_VERSION=2024-10-21
# SECRET — do NOT commit. Set in your shell/CI, not in a committed .env:
# PIPELINE_AZURE_OPENAI_API_KEY=

# ── Chunking ──────────────────────────────────────────────────────────────────
# Maximum characters per semantic chunk before splitting.
PIPELINE_MAX_CHUNK_CHARS=2000

# ── Vector store (ChromaDB) ───────────────────────────────────────────────────
# Directory where ChromaDB persists the HNSW index.
PIPELINE_CHROMA_PERSIST_DIR=./data/chroma
# Collection name inside ChromaDB.
PIPELINE_COLLECTION_NAME=sdd_docs

# ── Telemetry ─────────────────────────────────────────────────────────────────
# Opt out of ChromaDB anonymous telemetry.
ANONYMIZED_TELEMETRY=false
