{
  "servers": {
    "sdd-semantic": {
      "type": "stdio",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "-m",
        "sdd_pipeline.cli",
        "mcp",
        "--model",
        "BAAI/bge-large-en-v1.5",
        "--provider",
        "local"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYTHONUTF8": "1",
        "PIPELINE_CHROMA_PERSIST_DIR": "${workspaceFolder}/outbox/index",
        "PIPELINE_COLLECTION_NAME": "sdd_docs",
        "PIPELINE_VECTOR_STORE_BACKEND": "memory",
        "PIPELINE_EMBEDDING_PROVIDER": "local",
        "PIPELINE_EMBEDDING_MODEL": "BAAI/bge-large-en-v1.5"
      }
    }
  }
}
