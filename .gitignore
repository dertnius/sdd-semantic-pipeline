# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Tooling caches / coverage ────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ── Secrets / local config ───────────────────────────────────────────────────
# Never commit a real .env (it holds PIPELINE_AZURE_OPENAI_API_KEY etc.).
.env
.env.*
!.env.example

# ── Workspace contract: inbox / outbox ───────────────────────────────────────
# All pipeline OUTPUT lives under outbox/ (index/, md/, chunks/, reports/,
# vocab/, taxonomy/, dump/ — see outbox/.gitkeep). Ignore it wholesale but keep
# the folder skeleton so a fresh clone has the default output root.
/outbox/*
!/outbox/.gitkeep
# Pipeline INPUT lives under inbox/ (raw HTML/MD the user drops in). Keep the
# folder skeleton, but never commit the (often confidential) source files.
/inbox/**
!/inbox/**/
!/inbox/**/.gitkeep

# ── Side-loaded embedding models (offline / restricted network) ──────────────
# Model weights copied in by hand for the local sentence-transformers provider
# when HuggingFace is unreachable. Large binaries — never commit; point
# PIPELINE_EMBEDDING_MODEL at a path under here (see .env.example).
/models/

# ── Generated pipeline artifacts (belt-and-braces) ───────────────────────────
# build/ is still produced by setuptools (build/lib, build/bdist); keep ignored.
build/
# per-file export artifacts + reports, wherever they land outside outbox/
*.chunks.json
*.chunks.jsonl
export-report.json
conversion-report.json
quality-report.json
# scratch / temp
.tmp_dc/
.tmp_pytest/
# transient test-run output dirs (e.g. tests/convert/examples/out/) — never committed
out/
# e2e corpus: fetched on demand from src/tools/eval/e2e_sources.yaml, never committed
src/tools/eval/e2e_corpus/
# NOTE: config/entity-vocab.json + config/taxonomy.json are committed seed
# examples — keep them tracked (config/ is not ignored).
# Regenerated each eval run; holds machine-specific absolute-path doc_id hashes.
src/tools/eval/corpus_manifest.json

# ── Docs site (MkDocs build output) ──────────────────────────────────────────
# `mkdocs build` renders ./site from docs/; the Markdown under docs/ is the source.
/site/
# GitLab Pages builds into ./public (CI `pages` job: `mkdocs build --site-dir public`).
/public/

# ── Editors / OS ─────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Claude Code session data (local, not for the repo) ───────────────────────
.claude/

# NOTE: .vscode/, .github/, .devcontainer/ are intentionally tracked
# (the README documents them as part of the project) — do NOT ignore them.
