# Build context for the production Containerfile (root) and the dev image
# .devcontainer/Dockerfile. Podman/buildah read .containerignore natively (and
# fall back to .dockerignore if absent). Both builds COPY only pyproject.toml,
# README.md and src/, so keep the context lean — the working tree is bind-mounted
# at runtime.

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Pipeline workspace zones (large and/or confidential) ──────────────────────
outbox/
inbox/

# ── Build + packaging output ──────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ── Caches ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# ── VCS + secrets ─────────────────────────────────────────────────────────────
.git/
.github/
.env
.env.*

# ── Editors / OS / agent ──────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
.DS_Store
Thumbs.db

# ── Not needed to build the image ─────────────────────────────────────────────
docs/
tests/
k8s/
scripts/
src/tools/eval/e2e_corpus/
